            { lema: "al + infinitivo", descripcion: "一做……的时候", ejemplo: "Al salir, encontré a Ana.", tipo: "frase", libro: 2, etiqueta: "B1" },
            // ========== 第三册 (主要B1，部分B2) ==========
            { lema: "aconsejar + que + subj.", descripcion: "建议……", ejemplo: "Te aconsejo que estudies más.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "pedir + que + subj.", descripcion: "请求……", ejemplo: "Pido que me ayuden.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "hacer falta + que + subj.", descripcion: "需要", ejemplo: "Hace falta que vengas.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "dudar + que + subj.", descripcion: "怀疑……", ejemplo: "Dudo que sea verdad.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "no creer + que + subj.", descripcion: "不相信……", ejemplo: "No creo que llegue hoy.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "alegrarse + de que + subj.", descripcion: "高兴……", ejemplo: "Me alegro de que estés bien.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "sentir + que + subj.", descripcion: "抱歉/遗憾", ejemplo: "Siento que no puedas venir.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "extrañarse + de que + subj.", descripcion: "对……感到奇怪", ejemplo: "Me extraña que no lo sepa.", tipo: "frase", libro: 3, etiqueta: "B2" },
            { lema: "temer + que + subj.", descripcion: "害怕……", ejemplo: "Temo que llueva.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "prohibir + que + subj.", descripcion: "禁止", ejemplo: "Prohíben que se fume.", tipo: "frase", libro: 3, etiqueta: "B1" },
            { lema: "decir + que + subj. (no afirmativo)", descripcion: "让某人做(命令/愿望)", ejemplo: "Dile que venga.", tipo: "frase", libro: 3, etiqueta: "B2" },
            { lema: "abstenerse + de", descripcion: "克制不做", ejemplo: "Me abstengo de opinar.", tipo: "verbo+prep", libro: 3, etiqueta: "B2" },
            { lema: "tratar + de + infinitivo", descripcion: "试图做", ejemplo: "Trato de ayudarte.", tipo: "verbo+prep", libro: 3, etiqueta: "B1" },
            { lema: "renunciar + a", descripcion: "放弃", ejemplo: "Renuncio al puesto.", tipo: "verbo+prep", libro: 3, etiqueta: "B2" },
            // ========== 第四册 (主要B2，部分C1) ==========
            { lema: "influir + en", descripcion: "影响", ejemplo: "Influye en mi decisión.", tipo: "verbo+prep", libro: 4, etiqueta: "B2" },
            { lema: "participar + en", descripcion: "参与", ejemplo: "Participa en el concurso.", tipo: "verbo+prep", libro: 4, etiqueta: "B2" },
            { lema: "confrontar + con", descripcion: "面对, 对照", ejemplo: "Confronta sus ideas con las mías.", tipo: "verbo+prep", libro: 4, etiqueta: "B2" },
            { lema: "protestar + por / contra", descripcion: "抗议", ejemplo: "Protestan por la injusticia.", tipo: "verbo+prep", libro: 4, etiqueta: "B2" },
            { lema: "traducir + a", descripcion: "翻译成(语言)", ejemplo: "Traduce al chino.", tipo: "verbo+prep", libro: 4, etiqueta: "B2" },
            { lema: "oponerse + a", descripcion: "反对", ejemplo: "Me opongo a ese plan.", tipo: "verbo+prep", libro: 4, etiqueta: "B2" },
            { lema: "referirse + a", descripcion: "提及, 指的是", ejemplo: "Se refiere al libro.", tipo: "verbo+prep", libro: 4, etiqueta: "B2" },
            { lema: "asistir + a", descripcion: "出席, 参加", ejemplo: "Asiste a la reunión.", tipo: "verbo+prep", libro: 4, etiqueta: "B2" },
            { lema: "acceder + a", descripcion: "同意, 进入", ejemplo: "Accede a nuestra petición.", tipo: "verbo+prep", libro: 4, etiqueta: "C1" },
            { lema: "contribuir + a", descripcion: "促进, 捐助", ejemplo: "Contribuye al desarrollo.", tipo: "verbo+prep", libro: 4, etiqueta: "C1" },
            { lema: "traer + consigo", descripcion: "带来, 伴随", ejemplo: "El cambio trae consigo problemas.", tipo: "frase", libro: 4, etiqueta: "C1" },
            { lema: "en cuanto a", descripcion: "关于, 至于", ejemplo: "En cuanto a mí, no sé.", tipo: "frase", libro: 4, etiqueta: "B2" },
            { lema: "a base de", descripcion: "基于, 通过", ejemplo: "Vive a base de frutas.", tipo: "frase", libro: 4, etiqueta: "B2" },
        ];

        // ---------- 用户自定义数据 (保存在localStorage) ----------
        let userData = [];

        try {
            const stored = localStorage.getItem('userVerbsData');
            if (stored) {
                userData = JSON.parse(stored);
                if (!Array.isArray(userData)) userData = [];
            }
        } catch (e) {
            console.warn("读取localStorage失败", e);
            userData = [];
        }

        // 合并数据
        let data = [...builtinData, ...userData];

        // 界面元素
        const grid = document.getElementById('entries-grid');
        const buscador = document.getElementById('buscador');
        const filtroLibro = document.getElementById('filtro-libro');
        const totalSpan = document.getElementById('total-count');
        const count1 = document.getElementById('count1');
        const count2 = document.getElementById('count2');
        const count3 = document.getElementById('count3');
        const count4 = document.getElementById('count4');
        const tagButtons = document.querySelectorAll('[data-tipo]');
        const btnAdd = document.getElementById('btn-add');
        const btnClear = document.getElementById('btn-clear');
        const newLema = document.getElementById('new-lema');
        const newDesc = document.getElementById('new-desc');
        const newEjemplo = document.getElementById('new-ejemplo');
        const newLibro = document.getElementById('new-libro');
        const newTipo = document.getElementById('new-tipo');
        const newEtiqueta = document.getElementById('new-etiqueta');

        // 当前过滤状态
        let currentTag = 'all';
        let currentSearch = '';
        let currentLibro = 'all';

        // 更新统计数字
        function updateStats() {
            totalSpan.innerText = data.length;
            count1.innerText = data.filter(d => d.libro === 1).length;
            count2.innerText = data.filter(d => d.libro === 2).length;
            count3.innerText = data.filter(d => d.libro === 3).length;
            count4.innerText = data.filter(d => d.libro === 4).length;
        }
        updateStats();

        function normalize(text) {
            return text.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        }

        function filterData() {
            return data.filter(item => {
                if (currentLibro !== 'all' && item.libro !== parseInt(currentLibro)) return false;

                if (currentTag !== 'all') {
                    // 类型过滤
                    if (currentTag === 'verbo+prep' && item.tipo !== 'verbo+prep') return false;
                    if (currentTag === 'frase' && item.tipo !== 'frase') return false;
                    // 难度过滤 (A1, A2, B1, B2, C1)
                    if (['A1','A2','B1','B2','C1'].includes(currentTag) && item.etiqueta !== currentTag) return false;
                }

                if (currentSearch.trim() !== '') {
                    const term = normalize(currentSearch);
                    const inLema = normalize(item.lema).includes(term);
                    const inDesc = normalize(item.descripcion).includes(term);
                    const inEjem = item.ejemplo ? normalize(item.ejemplo).includes(term) : false;
                    if (!(inLema || inDesc || inEjem)) return false;
                }
                return true;
            });
        }

        function highlightText(text, search) {
            if (!search.trim()) return text;
            const term = search.trim().replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            const regex = new RegExp(`(${term})`, 'gi');
            if (typeof text === 'string') {
                return text.replace(regex, `<span class="highlight">$1</span>`);
            }
            return text;
        }

        function render() {
            const filtered = filterData();
            if (filtered.length === 0) {
                grid.innerHTML = `<div class="empty-message">😕 没有找到匹配的搭配。试试其他关键词，或者添加新条目！</div>`;
                return;
            }

            let html = '';
            filtered.forEach(item => {
                const isUserEntry = item._user === true;
                const lemah = currentSearch ? highlightText(item.lema, currentSearch) : item.lema;
                const desch = currentSearch ? highlightText(item.descripcion, currentSearch) : item.descripcion;
                const ejh = currentSearch && item.ejemplo ? highlightText(item.ejemplo, currentSearch) : (item.ejemplo || '');
                const levelClass = `level-${item.etiqueta}`;

                const entryClass = isUserEntry ? 'user-added' : '';

                html += `<div class="entry ${entryClass}">`;
                html += `<div class="lema">${lemah} <small>${desch}</small> ${isUserEntry ? '<span class="user-badge">自建</span>' : ''}</div>`;
                if (item.ejemplo) {
                    html += `<div class="ejemplo"><i>${ejh}</i></div>`;
                }
                html += `<div class="meta">`;
                html += `<span>📚 第 ${item.libro} 册</span>`;
                html += `<span class="${levelClass}">🏷️ ${item.etiqueta}</span>`;
                html += `<span>${item.tipo === 'verbo+prep' ? '🔗 动介搭配' : '💬 短语/句式'}</span>`;
                html += `</div></div>`;
            });

            grid.innerHTML = html;
        }

        function rebuildData() {
            data = [...builtinData, ...userData];
            updateStats();
            render();
        }

        function saveUserData() {
            localStorage.setItem('userVerbsData', JSON.stringify(userData));
        }

        function addEntry() {
            const lema = newLema.value.trim();
            const desc = newDesc.value.trim();
            const ejemplo = newEjemplo.value.trim();
            const libro = parseInt(newLibro.value);
            const tipo = newTipo.value;
            const etiqueta = newEtiqueta.value; // "A1","A2","B1","B2","C1"

            if (!lema || !desc) {
                alert("请至少填写动词短语和中文释义");
                return;
            }

            const newEntry = {
                lema: lema,
                descripcion: desc,
                ejemplo: ejemplo || '',
                libro: libro,
                tipo: tipo,
                etiqueta: etiqueta,
                _user: true
            };

            userData.push(newEntry);
            saveUserData();
            rebuildData();

            // 清空表单
            newLema.value = '';
            newDesc.value = '';
            newEjemplo.value = '';
            newLibro.value = '1';
            newTipo.value = 'verbo+prep';
            newEtiqueta.value = 'A1';
        }

        function clearForm() {
            newLema.value = '';
            newDesc.value = '';
            newEjemplo.value = '';
            newLibro.value = '1';
            newTipo.value = 'verbo+prep';
            newEtiqueta.value = 'A1';
        }

        btnAdd.addEventListener('click', addEntry);
        btnClear.addEventListener('click', clearForm);

        function handleInput() {
            currentSearch = buscador.value;
            render();
        }

        function handleLibroChange() {
            currentLibro = filtroLibro.value;
            render();
        }

        tagButtons.forEach(btn => {
            btn.addEventListener('click', (e) => {
                tagButtons.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                currentTag = btn.dataset.tipo;
                render();
            });
        });

        buscador.addEventListener('input', handleInput);
        filtroLibro.addEventListener('change', handleLibroChange);

        // 初始渲染
        rebuildData();
    })();
</script>
</body>
</html>
